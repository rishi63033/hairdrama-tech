# ─── Supabase / PostgreSQL ────────────────────────────────────────────────────
# Connection string from Supabase dashboard → Settings → Database → URI
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ─── Google OAuth ────────────────────────────────────────────────────────────
# From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# ─── JWT ─────────────────────────────────────────────────────────────────────
# A strong random secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your_super_secret_jwt_key_here

# ─── Gmail SMTP ──────────────────────────────────────────────────────────────
# Gmail address used to send notifications
GMAIL_ADDRESS=your-notifications@gmail.com
# Gmail App Password (NOT your regular password)
# Google Account → Security → 2-Step Verification → App Passwords
GMAIL_APP_PASSWORD=your_16_char_app_password

# ─── Flask ───────────────────────────────────────────────────────────────────
FLASK_ENV=development
SECRET_KEY=another_random_secret_for_flask_sessions

# ─── CORS ────────────────────────────────────────────────────────────────────
# Frontend URL (local dev or Vercel URL)
FRONTEND_URL=http://localhost:3000
