# ─── Backend API ─────────────────────────────────────────────────────────────
# URL of your Flask backend (local dev or Railway/Render URL)
NEXT_PUBLIC_API_URL=http://localhost:5000

# ─── Google OAuth ────────────────────────────────────────────────────────────
# Client ID from Google Cloud Console (same value as GOOGLE_CLIENT_ID in backend)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
